{
  "name": "@etip/root",
  "version": "4.0.0",
  "private": true,
  "description": "IntelWatch ETIP v4.0 — Enterprise Threat Intelligence Platform",
  "author": "IntelWatch Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": "9.15.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @etip/api-gateway... run build",
    "build:frontend": "pnpm --filter @etip/frontend run build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r exec rm -rf dist node_modules/.cache",
    "db:generate": "prisma generate --schema=prisma/schema.prisma"
  },
  "devDependencies": {
    "@prisma/client": "^5.18.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "7",
    "@typescript-eslint/parser": "7",
    "eslint": "8",
    "prettier": "^3.3.0",
    "prisma": "^5.18.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
