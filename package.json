{
  "name": "@etip/root",
  "version": "4.0.0",
  "private": true,
  "description": "IntelWatch ETIP v4.0 — Enterprise Threat Intelligence Platform",
  "author": "IntelWatch Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @etip/api-gateway dev",
    "dev:frontend": "pnpm --filter @etip/frontend dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:integration": "pnpm -r test:integration",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @etip/api-gateway prisma migrate dev",
    "db:generate": "pnpm --filter @etip/api-gateway prisma generate",
    "db:seed": "pnpm --filter @etip/api-gateway prisma db seed",
    "docker:up": "docker compose -p etip -f docker-compose.etip.yml up -d",
    "docker:down": "docker compose -p etip -f docker-compose.etip.yml down",
    "docker:logs": "docker compose -p etip -f docker-compose.etip.yml logs -f",
    "docker:ps": "docker compose -p etip -f docker-compose.etip.yml ps",
    "clean": "pnpm -r exec rm -rf dist node_modules/.cache",
    "scaffold": "node scripts/scaffold.js",
    "sdk:generate": "bash scripts/generate-sdk.sh",
    "audit": "pnpm audit --audit-level=high",
    "prepare": "echo 'Ready'"
  },
  "devDependencies": {
    "@prisma/client": "5.22.0",
    "@types/node": "^20.14.0",
    "ioredis": "^5.4.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.5.0",
    "globals": "^17.4.0",
    "prettier": "^3.3.0",
    "prisma": "^5.18.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
