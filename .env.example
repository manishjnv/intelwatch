# ---------------------------------------------------------
# Feed Engine Module — Environment Variables
# Copy this file to .env and fill in your values
# ---------------------------------------------------------

# General
ENVIRONMENT=development
LOG_LEVEL=INFO
MODULE_ID=feed-engine
MODULE_VERSION=1.0.0

# Platform integration
# URL of the main IntelWatch platform (used for module registration)
PLATFORM_URL=http://platform:8000
# Shared secret between this module and the platform (X-Module-Key header)
MODULE_API_KEY=change-me-use-a-strong-random-secret
MODULE_PORT=8001

# PostgreSQL (same DB as the platform, module uses feed.* schema)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=threat_intel
POSTGRES_USER=ti_user
POSTGRES_PASSWORD=changeme

# Redis (same Redis as the platform, module uses 'feeds' queue)
REDIS_URL=redis://redis:6379/0

# ---- Feed API Keys ----
# NVD — https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# AbuseIPDB — https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# AlienVault OTX — https://otx.alienvault.com/api
OTX_API_KEY=

# VirusTotal — https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Shodan — https://account.shodan.io/
SHODAN_API_KEY=

# ---- Feed Scheduling ----
# Default interval in minutes for feeds that don't have a specific schedule
FEED_POLL_INTERVAL_MINUTES=60
FEED_RETRY_ATTEMPTS=3
FEED_TIMEOUT_SECONDS=60

# ---- Plan Limits ----
MAX_FEEDS_FREE=5
MAX_FEEDS_STARTER=999
DELAY_HOURS_FREE=24
