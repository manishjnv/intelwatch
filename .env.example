# ═══════════════════════════════════════════════════════════════════════
# ETIP v4.0 — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# ALL production secrets MUST use TI_ prefix.
# NEVER commit .env to git — only .env.example is tracked.
# ═══════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────
TI_NODE_ENV=development
TI_API_PORT=3001
TI_API_HOST=0.0.0.0
TI_FRONTEND_PORT=3002
TI_FRONTEND_URL=http://localhost:3002
TI_LOG_LEVEL=info
TI_LOG_FORMAT=json

# ─── PostgreSQL ───────────────────────────────────────────────────
TI_POSTGRES_HOST=localhost
TI_POSTGRES_PORT=5433
TI_POSTGRES_DB=etip
TI_POSTGRES_USER=etip_user
TI_POSTGRES_PASSWORD=CHANGE_ME_postgres_password
TI_POSTGRES_POOL_SIZE=20
TI_POSTGRES_POOL_IDLE_TIMEOUT=30000
TI_DATABASE_URL=postgresql://${TI_POSTGRES_USER}:${TI_POSTGRES_PASSWORD}@${TI_POSTGRES_HOST}:${TI_POSTGRES_PORT}/${TI_POSTGRES_DB}?schema=public

# ─── Redis ────────────────────────────────────────────────────────
TI_REDIS_HOST=localhost
TI_REDIS_PORT=6380
TI_REDIS_PASSWORD=CHANGE_ME_redis_password
TI_REDIS_URL=redis://:${TI_REDIS_PASSWORD}@${TI_REDIS_HOST}:${TI_REDIS_PORT}/0

# ─── Elasticsearch ────────────────────────────────────────────────
TI_ELASTICSEARCH_HOST=localhost
TI_ELASTICSEARCH_PORT=9201
TI_ELASTICSEARCH_USERNAME=elastic
TI_ELASTICSEARCH_PASSWORD=CHANGE_ME_elastic_password
TI_ELASTICSEARCH_URL=http://${TI_ELASTICSEARCH_HOST}:${TI_ELASTICSEARCH_PORT}

# ─── Neo4j ────────────────────────────────────────────────────────
TI_NEO4J_HOST=localhost
TI_NEO4J_BOLT_PORT=7688
TI_NEO4J_HTTP_PORT=7475
TI_NEO4J_USERNAME=neo4j
TI_NEO4J_PASSWORD=CHANGE_ME_neo4j_password
TI_NEO4J_URL=bolt://${TI_NEO4J_HOST}:${TI_NEO4J_BOLT_PORT}

# ─── MinIO (S3-Compatible) ───────────────────────────────────────
TI_MINIO_ENDPOINT=${TI_MINIO_HOST:-localhost}:${TI_MINIO_API_PORT:-9001}
TI_MINIO_API_PORT=9001
TI_MINIO_CONSOLE_PORT=9002
TI_MINIO_ACCESS_KEY=etip_minio_admin
TI_MINIO_SECRET_KEY=CHANGE_ME_minio_password
TI_MINIO_BUCKET=etip-exports
TI_MINIO_USE_SSL=false

# ─── JWT ──────────────────────────────────────────────────────────
TI_JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars_long
TI_JWT_ACCESS_EXPIRY=900
TI_JWT_REFRESH_EXPIRY=604800
TI_JWT_ISSUER=intelwatch-etip
TI_SERVICE_JWT_SECRET=CHANGE_ME_service_jwt_secret_min_16_chars

# ─── Google OAuth 2.0 SSO ────────────────────────────────────────
TI_GOOGLE_CLIENT_ID=
TI_GOOGLE_CLIENT_SECRET=
TI_GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/sso/google/callback

# ─── SAML 2.0 (Enterprise SSO) ───────────────────────────────────
TI_SAML_ENTRY_POINT=
TI_SAML_ISSUER=intelwatch-etip
TI_SAML_CERT=
TI_SAML_CALLBACK_URL=http://localhost:3001/api/v1/auth/sso/saml/callback

# ─── OIDC (OpenID Connect) ───────────────────────────────────────
TI_OIDC_ISSUER_URL=
TI_OIDC_CLIENT_ID=
TI_OIDC_CLIENT_SECRET=
TI_OIDC_CALLBACK_URL=http://localhost:3001/api/v1/auth/sso/oidc/callback

# ─── MFA (TOTP + SMS) ────────────────────────────────────────────
TI_MFA_ISSUER=IntelWatch
TI_TWILIO_ACCOUNT_SID=
TI_TWILIO_AUTH_TOKEN=
TI_TWILIO_PHONE_NUMBER=

# ─── Magic Code (Passwordless Email) ─────────────────────────────
TI_SMTP_HOST=
TI_SMTP_PORT=587
TI_SMTP_USER=
TI_SMTP_PASSWORD=
TI_SMTP_FROM=noreply@intelwatch.in

# ─── Claude AI API ───────────────────────────────────────────────
TI_CLAUDE_API_KEY=
TI_CLAUDE_SONNET_MODEL=claude-sonnet-4-20250514
TI_CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
TI_CLAUDE_BATCH_MIN_SIZE=10
TI_CLAUDE_CACHE_TARGET=0.8
TI_CLAUDE_MAX_RETRIES=3
TI_CLAUDE_TIMEOUT_MS=30000

# ─── External APIs ───────────────────────────────────────────────
TI_VIRUSTOTAL_API_KEY=
TI_ABUSEIPDB_API_KEY=
TI_SHODAN_API_KEY=
TI_NVD_API_KEY=

# ─── Stripe (Billing) ────────────────────────────────────────────
TI_STRIPE_SECRET_KEY=
TI_STRIPE_PUBLISHABLE_KEY=
TI_STRIPE_WEBHOOK_SECRET=

# ─── Rate Limiting ───────────────────────────────────────────────
TI_RATE_LIMIT_WINDOW_MS=60000
TI_RATE_LIMIT_MAX_REQUESTS=100
TI_RATE_LIMIT_MAX_REQUESTS_IP=10000

# ─── CORS ─────────────────────────────────────────────────────────
TI_CORS_ORIGINS=http://localhost:3002,http://localhost:5173

# ─── Monitoring ───────────────────────────────────────────────────
TI_PROMETHEUS_PORT=9190
TI_GRAFANA_PORT=3101
TI_GRAFANA_USER=admin
TI_GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# ─── Nginx ────────────────────────────────────────────────────────
TI_NGINX_HTTP_PORT=8080
TI_NGINX_HTTPS_PORT=8443

# ─── Feature Flags ───────────────────────────────────────────────
TI_FEATURE_DARK_MODE=true
TI_FEATURE_GRAPH_BETA=false
TI_FEATURE_AI_ENRICHMENT=true
TI_FEATURE_DRP=false

# ─── Claude AI — Token Budgets Per Module ──────────────────────────
TI_CLAUDE_OPUS_MODEL=claude-opus-4-6
TI_TOKEN_BUDGET_ENRICHMENT_DAILY=500000
TI_TOKEN_BUDGET_CORRELATION_DAILY=200000
TI_TOKEN_BUDGET_HUNTING_DAILY=100000
TI_TOKEN_BUDGET_REPORTS_DAILY=50000
TI_TOKEN_BUDGET_DEFAULT_DAILY=100000
TI_TOKEN_ALERT_THRESHOLD=0.8
TI_TOKEN_FALLBACK_TO_HAIKU=true

# ─── Cache TTLs (seconds) ──────────────────────────────────────────
TI_CACHE_TTL_DASHBOARD=172800
TI_CACHE_TTL_IOC_IP=3600
TI_CACHE_TTL_IOC_DOMAIN=86400
TI_CACHE_TTL_IOC_HASH=604800
TI_CACHE_TTL_IOC_CVE=43200
TI_CACHE_TTL_IOC_URL=3600
TI_CACHE_TTL_IOC_EMAIL=86400
TI_CACHE_TTL_USER_SESSION=900
TI_CACHE_TTL_FEED_META=1800
TI_CACHE_TTL_SEARCH_RESULTS=3600

# ─── Archive Policy ────────────────────────────────────────────────
TI_ARCHIVE_AFTER_DAYS=60
TI_ARCHIVE_FORMAT=parquet
TI_ARCHIVE_BUCKET=etip-archive
TI_ARCHIVE_REPORTS_BUCKET=etip-reports
TI_ARCHIVE_RETRIEVAL_MAX_DAYS=180
TI_COLD_STORAGE_ENABLED=false

# ─── Authentication — Admin ────────────────────────────────────────
TI_ADMIN_MAGIC_CODE_HASH=CHANGE_ME_bcrypt_hash_of_admin_code
TI_ADMIN_EMAIL=admin@intelwatch.in
TI_SESSION_SECRET=CHANGE_ME_session_secret_min_32_chars

# ─── External Threat Intel APIs ────────────────────────────────────
TI_MISP_URL=
TI_MISP_API_KEY=
TI_MISP_VERIFY_SSL=true
TI_TAXII_SERVER_URL=
TI_TAXII_USERNAME=
TI_TAXII_PASSWORD=
TI_URLSCAN_API_KEY=
TI_MALWAREBAZAAR_API_KEY=
TI_IPINFO_API_KEY=

# ─── Integrations ──────────────────────────────────────────────────
TI_SLACK_WEBHOOK_URL=
TI_SLACK_BOT_TOKEN=
TI_PAGERDUTY_API_KEY=
TI_PAGERDUTY_SERVICE_ID=
TI_SERVICENOW_INSTANCE_URL=
TI_SERVICENOW_USERNAME=
TI_SERVICENOW_PASSWORD=
TI_SPLUNK_HEC_URL=
TI_SPLUNK_HEC_TOKEN=
TI_SENTINEL_WORKSPACE_ID=
TI_SENTINEL_SHARED_KEY=
TI_JIRA_BASE_URL=
TI_JIRA_USERNAME=
TI_JIRA_API_TOKEN=
TI_JIRA_PROJECT_KEY=

# ─── Frontend Public Variables ─────────────────────────────────────
TI_NEXT_PUBLIC_APP_URL=http://localhost:3002
TI_NEXT_PUBLIC_API_URL=http://localhost:3001
TI_NEXT_PUBLIC_WS_URL=ws://localhost:3001
TI_NEXT_PUBLIC_APP_NAME=IntelWatch
TI_NEXT_PUBLIC_APP_VERSION=4.0.0

# ─── VPS Deployment ────────────────────────────────────────────────
TI_VPS_HOST=your_vps_ip_here
TI_VPS_USER=root
TI_VPS_SSH_PORT=22
TI_VPS_DEPLOY_PATH=/opt/etip
TI_DOMAIN=intelwatch.in
TI_API_DOMAIN=api.intelwatch.in

# ─── GitHub ────────────────────────────────────────────────────────
TI_GITHUB_REPO=https://github.com/manishjnv/intelwatch
TI_GITHUB_REGISTRY=ghcr.io/manishjnv/intelwatch

# ─── Feature Flags — Phase Gates ───────────────────────────────────
# Phase 1: Foundation
TI_FEATURE_AUTH=true
TI_FEATURE_API_GATEWAY=true
# Phase 2: Data Pipeline
TI_FEATURE_INGESTION=false
TI_FEATURE_NORMALIZATION=false
TI_FEATURE_AI_ENRICHMENT_PIPELINE=false
# Phase 3: Core Intelligence
TI_FEATURE_IOC_MODULE=false
TI_FEATURE_THREAT_ACTOR=false
TI_FEATURE_MALWARE=false
TI_FEATURE_VULNERABILITY=false
# Phase 4: Advanced Intelligence
TI_FEATURE_GRAPH=false
TI_FEATURE_CORRELATION=false
TI_FEATURE_HUNTING=false
TI_FEATURE_DRP_MODULE=false
# Phase 5: Platform
TI_FEATURE_ENTERPRISE_INTEGRATION=false
TI_FEATURE_SAML_SSO=false
TI_FEATURE_MFA=false
# Phase 6: Growth
TI_FEATURE_ONBOARDING_WIZARD=false
TI_FEATURE_BILLING=false
TI_FEATURE_FREE_TO_PAID=false
# Phase 7: Performance
TI_FEATURE_ARCHIVAL=false
TI_FEATURE_CACHE_WARMING=false
# Phase 8: UI Polish
TI_FEATURE_3D_EFFECTS=true
TI_FEATURE_ENTITY_CHIPS=true
TI_FEATURE_GLOBAL_SEARCH=false
TI_FEATURE_AGENTIC_HUNTING=false
