{
  "id": "feed-engine",
  "name": "Feed Engine",
  "version": "1.0.0",
  "description": "Threat intelligence feed ingestion, normalization, deduplication, and scoring",
  "capabilities": ["ingest", "schedule", "trigger", "health", "config"],
  "api_base": "http://localhost:8001",
  "health_endpoint": "/health",
  "plan_required": "free",
  "feeds": [
    { "id": "nvd",            "name": "NVD CVE Feed",        "interval_minutes": 30,   "requires_api_key": true  },
    { "id": "kev",            "name": "CISA KEV",            "interval_minutes": 360,  "requires_api_key": false },
    { "id": "urlhaus",        "name": "URLhaus",             "interval_minutes": 60,   "requires_api_key": false },
    { "id": "otx",            "name": "AlienVault OTX",      "interval_minutes": 120,  "requires_api_key": true  },
    { "id": "threatfox",      "name": "ThreatFox",           "interval_minutes": 60,   "requires_api_key": false },
    { "id": "malwarebazaar",  "name": "MalwareBazaar",       "interval_minutes": 120,  "requires_api_key": false },
    { "id": "virustotal",     "name": "VirusTotal",          "interval_minutes": 240,  "requires_api_key": true  },
    { "id": "shodan",         "name": "Shodan",              "interval_minutes": 720,  "requires_api_key": true  },
    { "id": "abuseipdb",      "name": "AbuseIPDB",           "interval_minutes": 240,  "requires_api_key": true  },
    { "id": "cisa_advisories","name": "CISA Advisories",     "interval_minutes": 360,  "requires_api_key": false },
    { "id": "exploitdb",      "name": "Exploit-DB",          "interval_minutes": 720,  "requires_api_key": false },
    { "id": "mitre_attack",   "name": "MITRE ATT&CK",        "interval_minutes": 10080,"requires_api_key": false }
  ],
  "config_schema": {
    "nvd_api_key":                  { "type": "string",  "secret": true,  "label": "NVD API Key",                       "required": false },
    "abuseipdb_api_key":            { "type": "string",  "secret": true,  "label": "AbuseIPDB API Key",                "required": false },
    "otx_api_key":                  { "type": "string",  "secret": true,  "label": "AlienVault OTX Key",               "required": false },
    "virustotal_api_key":           { "type": "string",  "secret": true,  "label": "VirusTotal API Key",               "required": false },
    "shodan_api_key":               { "type": "string",  "secret": true,  "label": "Shodan API Key",                   "required": false },
    "feed_poll_interval_minutes":   { "type": "integer", "default": 60,   "label": "Default Poll Interval (minutes)",  "required": false }
  },
  "event_publishes": ["intel:ingested", "intel:batch_complete", "feed:error"],
  "event_subscribes": []
}
