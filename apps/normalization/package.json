    "@etip/shared-types": "workspace:*",
    "@etip/shared-utils": "workspace:*",
    "@prisma/client": "^5.19.0",
    "bullmq": "^5.13.0",
    "fastify": "^4.28.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.3.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.0",
    "pino": "^9.4.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@types/node": "^22.0.0"
