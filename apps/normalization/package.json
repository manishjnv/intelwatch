{
  "name": "@etip/normalization-service",
  "version": "1.0.0",
  "description": "ETIP IOC Normalization Service — dedup, lifecycle, composite confidence",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --no-error-on-unmatched-pattern"
  },
  "dependencies": {
    "@etip/shared-auth": "workspace:*",
