  @@index([itemId, itemType], name: "idx_apc_item")
  @@index([processedAt], name: "idx_apc_date")
  @@index([subtask], name: "idx_apc_subtask")
  @@index([provider], name: "idx_apc_provider")
  @@map("ai_processing_costs")
}

