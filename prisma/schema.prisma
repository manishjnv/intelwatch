// ETIP v4.0 — Prisma Schema (Phase 1: Foundation)
// Tables: tenants, users, sessions, api_keys, audit_logs

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("TI_DATABASE_URL")
}

model Tenant {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String   @db.VarChar(255)
  slug             String   @unique @db.VarChar(63)
  plan             Plan     @default(free)
  maxUsers         Int      @default(5) @map("max_users")
  maxFeedsPerDay   Int      @default(10) @map("max_feeds_per_day")
  maxIOCs          Int      @default(10000) @map("max_iocs")
  aiCreditsMonthly Int      @default(100) @map("ai_credits_monthly")
  aiCreditsUsed    Int      @default(0) @map("ai_credits_used")
  settings         Json     @default("{}")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  users       User[]
  sessions    Session[]
  apiKeys     ApiKey[]
  auditLogs   AuditLog[]
  feedSources FeedSource[]
  iocs        Ioc[]
  @@map("tenants")
}

enum Plan {
  free
  pro
  enterprise
  @@map("plan_enum")
}

model User {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  email          String       @db.VarChar(255)
  displayName    String       @db.VarChar(255) @map("display_name")
  avatarUrl      String?      @map("avatar_url") @db.Text
  role           Role         @default(viewer)
  authProvider   AuthProvider @default(email) @map("auth_provider")
  authProviderId String?      @map("auth_provider_id") @db.VarChar(255)
  passwordHash   String?      @map("password_hash") @db.VarChar(255)
  mfaEnabled     Boolean      @default(false) @map("mfa_enabled")
  mfaSecret      String?      @map("mfa_secret") @db.VarChar(255)
  lastLoginAt    DateTime?    @map("last_login_at")
  loginCount     Int          @default(0) @map("login_count")
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions  Session[]
  apiKeys   ApiKey[]
  auditLogs AuditLog[]
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

enum Role {
  super_admin
  tenant_admin
  analyst
  viewer
  api_only
  @@map("role_enum")
}

enum AuthProvider {
  email
  google
  saml
  oidc
  @@map("auth_provider_enum")
}

model Session {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") @db.VarChar(45)
  userAgent        String?   @map("user_agent") @db.Text
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("sessions")
}

model ApiKey {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  name      String    @db.VarChar(255)
  prefix    String    @db.VarChar(12)
  keyHash   String    @map("key_hash") @db.VarChar(255)
  scopes    String[]  @default(["ioc:read"])
  lastUsed  DateTime? @map("last_used")
  expiresAt DateTime? @map("expires_at")
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([userId])
  @@index([prefix])
  @@map("api_keys")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String   @db.VarChar(255)
  entityType   String   @map("entity_type") @db.VarChar(100)
  entityId     String?  @map("entity_id") @db.VarChar(255)
  changes      Json?
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Phase 2: Data Pipeline ───────────────────────────────────────────────────

enum FeedType {
  stix
  taxii
  misp
  rss
  rest_api
  nvd
  csv_upload
  json_upload
  webhook
  email_imap
  @@map("feed_type_enum")
}

enum FeedStatus {
  active
  paused
  error
  disabled
  @@map("feed_status_enum")
}

model FeedSource {
  id                   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String     @map("tenant_id") @db.Uuid
  name                 String     @db.VarChar(255)
  description          String?    @db.Text
  feedType             FeedType   @map("feed_type")
  url                  String?    @db.Text
  schedule             String?    @db.VarChar(100)   // cron expression
  headers              Json       @default("{}")
  authConfig           Json       @default("{}") @map("auth_config")  // encrypted at app layer
  parseConfig          Json       @default("{}") @map("parse_config")
  status               FeedStatus @default(active)
  enabled              Boolean    @default(true)
  // Health metrics
  lastFetchAt          DateTime?  @map("last_fetch_at")
  lastErrorAt          DateTime?  @map("last_error_at")
  lastErrorMessage     String?    @db.Text @map("last_error_message")
  consecutiveFailures  Int        @default(0) @map("consecutive_failures")
  totalItemsIngested   Int        @default(0) @map("total_items_ingested")
  itemsIngested24h     Int        @default(0) @map("items_ingested_24h")
  itemsRelevant24h     Int        @default(0) @map("items_relevant_24h")
  avgProcessingTimeMs  Int        @default(0) @map("avg_processing_time_ms")
  feedReliability      Int        @default(50) @map("feed_reliability") // 0-100
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  iocs     Ioc[]
  @@index([tenantId])
  @@index([status])
  @@index([feedType])
  @@map("feed_sources")
}

enum IocType {
  ip
  ipv6
  domain
  fqdn
  url
  email
  hash_md5
  hash_sha1
  hash_sha256
  hash_sha512
  cve
  asn
  cidr
  bitcoin_address
  unknown
  @@map("ioc_type_enum")
}

enum IocLifecycle {
  new
  active
  aging
  expired
  archived
  false_positive
  revoked
  @@map("ioc_lifecycle_enum")
}

enum Severity {
  info
  low
  medium
  high
  critical
  @@map("severity_enum")
}

enum TLP {
  white
  green
  amber
  red
  @@map("tlp_enum")
}

model Ioc {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String       @map("tenant_id") @db.Uuid
  feedSourceId     String?      @map("feed_source_id") @db.Uuid
  // Core fields
  iocType          IocType      @map("ioc_type")
  value            String       @db.Text
  normalizedValue  String       @map("normalized_value") @db.Text
  dedupeHash       String       @unique @map("dedupe_hash") @db.VarChar(64)
  // Classification
  severity         Severity     @default(medium)
  tlp              TLP          @default(amber)
  confidence       Int          @default(50)   // 0-100
  lifecycle        IocLifecycle @default(new)
  // Intel metadata
  tags             String[]     @default([])
  mitreAttack      String[]     @default([]) @map("mitre_attack")
  malwareFamilies  String[]     @default([]) @map("malware_families")
  threatActors     String[]     @default([]) @map("threat_actors")
  // Enrichment
  enrichmentData   Json?        @map("enrichment_data")   // EnrichmentOutput JSON
  enrichedAt       DateTime?    @map("enriched_at")
  // Timestamps
  firstSeen        DateTime     @default(now()) @map("first_seen")
  lastSeen         DateTime     @default(now()) @map("last_seen")
  expiresAt        DateTime?    @map("expires_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feedSource FeedSource? @relation(fields: [feedSourceId], references: [id], onDelete: SetNull)
  @@index([tenantId])
  @@index([tenantId, iocType])
  @@index([tenantId, severity])
  @@index([tenantId, lifecycle])
  @@index([normalizedValue])
  @@index([firstSeen])
  @@index([lastSeen])
  @@map("iocs")
}


