// ETIP v4.0 — Prisma Schema (Phase 1: Foundation)
// Tables: tenants, users, sessions, api_keys, audit_logs

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("TI_DATABASE_URL")
}

model Tenant {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String   @db.VarChar(255)
  slug             String   @unique @db.VarChar(63)
  plan             Plan     @default(free)
  maxUsers         Int      @default(5) @map("max_users")
  maxFeedsPerDay   Int      @default(10) @map("max_feeds_per_day")
  maxIOCs          Int      @default(10000) @map("max_iocs")
  aiCreditsMonthly Int      @default(100) @map("ai_credits_monthly")
  aiCreditsUsed    Int      @default(0) @map("ai_credits_used")
  settings         Json     @default("{}")
  active           Boolean  @default(true)
  // Offboarding lifecycle (I-19)
  offboardedAt       DateTime? @map("offboarded_at")
  purgeScheduledAt   DateTime? @map("purge_scheduled_at")
  offboardedBy       String?   @map("offboarded_by") @db.VarChar(255)
  offboardingStatus  String?   @map("offboarding_status") @db.VarChar(20)
  archivePath        String?   @map("archive_path") @db.VarChar(500)
  archiveHash        String?   @map("archive_hash") @db.VarChar(64)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  users       User[]
  sessions    Session[]
  apiKeys     ApiKey[]
  auditLogs   AuditLog[]
  feedSources          FeedSource[]
  iocs                 Ioc[]
  articles             Article[]
  threatActorProfiles  ThreatActorProfile[]
  malwareProfiles      MalwareProfile[]
  vulnerabilityProfiles VulnerabilityProfile[]
  subscriptions         TenantSubscription[]
  invoices              BillingInvoice[]
  usageRecords          BillingUsageRecord[]
  gracePeriods          BillingGracePeriod[]
  featureOverrides      TenantFeatureOverride[]
  ssoConfig             SsoConfig?
  scimTokens            ScimToken[]
  @@map("tenants")
}

enum Plan {
  free
  starter
  pro
  enterprise
  @@map("plan_enum")
}

model User {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  email          String       @db.VarChar(255)
  displayName    String       @db.VarChar(255) @map("display_name")
  avatarUrl      String?      @map("avatar_url") @db.Text
  role           Role         @default(analyst)
  authProvider   AuthProvider @default(email) @map("auth_provider")
  authProviderId String?      @map("auth_provider_id") @db.VarChar(255)
  passwordHash   String?      @map("password_hash") @db.VarChar(255)
  designation    String?      @db.VarChar(50)
  externalId     String?      @map("external_id") @db.VarChar(255)
  emailVerified      Boolean   @default(false) @map("email_verified")
  emailVerifyToken   String?   @map("email_verify_token") @db.VarChar(255)
  emailVerifyExpires DateTime? @map("email_verify_expires")
  mfaEnabled     Boolean      @default(false) @map("mfa_enabled")
  mfaSecret      String?      @map("mfa_secret") @db.VarChar(255)
  mfaBackupCodes String[]     @default([]) @map("mfa_backup_codes")
  mfaVerifiedAt  DateTime?    @map("mfa_verified_at")
  isBreakGlass       Boolean   @default(false) @map("is_break_glass")
  breakGlassLastUsed DateTime? @map("break_glass_last_used")
  breakGlassUseCount Int       @default(0) @map("break_glass_use_count")
  lastLoginAt    DateTime?    @map("last_login_at")
  loginCount     Int          @default(0) @map("login_count")
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions  Session[]
  apiKeys   ApiKey[]
  auditLogs AuditLog[]
  @@unique([tenantId, email])
  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

enum Role {
  super_admin
  tenant_admin
  analyst
  @@map("role_enum")
}

enum AuthProvider {
  email
  google
  saml
  oidc
  @@map("auth_provider_enum")
}

model Session {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") @db.VarChar(45)
  userAgent        String?   @map("user_agent") @db.Text
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  breakGlassSession Boolean  @default(false) @map("break_glass_session")
  geoCountry       String?   @map("geo_country") @db.VarChar(2)
  geoCity          String?   @map("geo_city") @db.VarChar(100)
  geoIsp           String?   @map("geo_isp") @db.VarChar(255)
  createdAt        DateTime  @default(now()) @map("created_at")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("sessions")
}

model ApiKey {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  name      String    @db.VarChar(255)
  prefix    String    @db.VarChar(12)
  keyHash   String    @map("key_hash") @db.VarChar(255)
  scopes    String[]  @default(["ioc:read"])
  lastUsed  DateTime? @map("last_used")
  expiresAt DateTime? @map("expires_at")
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([userId])
  @@index([prefix])
  @@map("api_keys")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String   @db.VarChar(255)
  entityType   String   @map("entity_type") @db.VarChar(100)
  entityId     String?  @map("entity_id") @db.VarChar(255)
  changes      Json?
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.Text
  hashChain    String?  @map("hash_chain") @db.VarChar(64)
  externalRef  String?  @map("external_ref") @db.VarChar(500)
  replicatedAt DateTime? @map("replicated_at")
  createdAt    DateTime @default(now()) @map("created_at")
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model MfaEnforcementPolicy {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String?  @unique @map("tenant_id") @db.Uuid
  scope      String   @db.VarChar(20) // "platform" or "org"
  enforced   Boolean  @default(false)
  enforcedBy String   @map("enforced_by") @db.VarChar(255)
  enforcedAt DateTime @default(now()) @map("enforced_at")
  @@map("mfa_enforcement_policies")
}

model SsoConfig {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @unique @map("tenant_id") @db.Uuid
  provider          String   @db.VarChar(20)
  entityId          String?  @map("entity_id") @db.VarChar(500)
  metadataUrl       String?  @map("metadata_url") @db.VarChar(500)
  clientId          String?  @map("client_id") @db.VarChar(255)
  clientSecret      String?  @map("client_secret") @db.VarChar(500)
  issuerUrl         String?  @map("issuer_url") @db.VarChar(500)
  certificate       String?  @db.Text
  groupRoleMappings Json     @default("[]") @map("group_role_mappings")
  approvedDomains   String[] @map("approved_domains")
  enabled           Boolean  @default(false)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@map("sso_configs")
}

// ─── Phase 2: Data Pipeline ───────────────────────────────────────────────────

enum FeedType {
  stix
  taxii
  misp
  rss
  rest_api
  nvd
  csv_upload
  json_upload
  webhook
  email_imap
  @@map("feed_type_enum")
}

enum FeedStatus {
  active
  paused
  error
  disabled
  @@map("feed_status_enum")
}

model FeedSource {
  id                   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String     @map("tenant_id") @db.Uuid
  name                 String     @db.VarChar(255)
  description          String?    @db.Text
  feedType             FeedType   @map("feed_type")
  url                  String?    @db.Text
  schedule             String?    @db.VarChar(100)   // cron expression
  headers              Json       @default("{}")
  authConfig           Json       @default("{}") @map("auth_config")  // encrypted at app layer
  parseConfig          Json       @default("{}") @map("parse_config")
  status               FeedStatus @default(active)
  enabled              Boolean    @default(true)
  // Health metrics
  lastFetchAt          DateTime?  @map("last_fetch_at")
  lastErrorAt          DateTime?  @map("last_error_at")
  lastErrorMessage     String?    @db.Text @map("last_error_message")
  consecutiveFailures  Int        @default(0) @map("consecutive_failures")
  totalItemsIngested   Int        @default(0) @map("total_items_ingested")
  itemsIngested24h     Int        @default(0) @map("items_ingested_24h")
  itemsRelevant24h     Int        @default(0) @map("items_relevant_24h")
  avgProcessingTimeMs  Int        @default(0) @map("avg_processing_time_ms")
  feedReliability      Int        @default(50) @map("feed_reliability") // 0-100
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  iocs     Ioc[]
  articles Article[]
  @@index([tenantId])
  @@index([status])
  @@index([feedType])
  @@map("feed_sources")
}

model Article {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String         @map("tenant_id") @db.Uuid
  feedSourceId        String         @map("feed_source_id") @db.Uuid
  // Raw content
  title               String         @db.VarChar(1000)
  content             String         @db.Text
  url                 String?        @db.Text
  publishedAt         DateTime?      @map("published_at")
  author              String?        @db.VarChar(500)
  language            String         @default("en") @db.VarChar(5)
  // Pipeline state
  pipelineStatus      PipelineStatus @default(ingested) @map("pipeline_status")
  isCtiRelevant       Boolean        @default(false) @map("is_cti_relevant")
  articleType         ArticleType    @default(irrelevant) @map("article_type")
  triageConfidence    Float          @default(0) @map("triage_confidence")
  triagePriority      String?        @map("triage_priority") @db.VarChar(20)
  triageResult        Json?          @map("triage_result")
  extractionResult    Json?          @map("extraction_result")
  // Cost tracking per stage
  stage1TriageTokens      Int        @default(0) @map("stage1_triage_tokens")
  stage1TriageCostUsd     Float      @default(0) @map("stage1_triage_cost_usd")
  stage2ExtractionTokens  Int        @default(0) @map("stage2_extraction_tokens")
  stage2ExtractionCostUsd Float      @default(0) @map("stage2_extraction_cost_usd")
  stage3DedupTokens       Int        @default(0) @map("stage3_dedup_tokens")
  stage3DedupCostUsd      Float      @default(0) @map("stage3_dedup_cost_usd")
  externalApiCalls        Int        @default(0) @map("external_api_calls")
  totalCostUsd            Float      @default(0) @map("total_cost_usd")
  // Extraction results
  iocsExtracted       Int            @default(0) @map("iocs_extracted")
  processingTimeMs    Int            @default(0) @map("processing_time_ms")
  dedupResult         Json?          @map("dedup_result")
  // Metadata
  rawMeta             Json?          @map("raw_meta")
  // Retention (I-20)
  archivedAt          DateTime?      @map("archived_at")
  archiveReason       String?        @map("archive_reason") @db.VarChar(50)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feedSource FeedSource @relation(fields: [feedSourceId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([tenantId, pipelineStatus])
  @@index([tenantId, isCtiRelevant])
  @@index([feedSourceId])
  @@index([publishedAt])
  @@index([createdAt])
  @@map("articles")
}

enum IocType {
  ip
  ipv6
  domain
  fqdn
  url
  email
  hash_md5
  hash_sha1
  hash_sha256
  hash_sha512
  cve
  asn
  cidr
  bitcoin_address
  unknown
  @@map("ioc_type_enum")
}

enum IocLifecycle {
  new
  active
  aging
  expired
  archived
  false_positive
  revoked
  reactivated
  @@map("ioc_lifecycle_enum")
}

enum PipelineStatus {
  ingested
  triaged
  extracted
  enriched
  deduplicated
  persisted
  failed
  @@map("pipeline_status_enum")
}

enum ArticleType {
  threat_report
  vulnerability_advisory
  news
  blog
  irrelevant
  @@map("article_type_enum")
}

enum Severity {
  info
  low
  medium
  high
  critical
  @@map("severity_enum")
}

enum TLP {
  white
  green
  amber
  red
  @@map("tlp_enum")
}

model Ioc {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String       @map("tenant_id") @db.Uuid
  feedSourceId     String?      @map("feed_source_id") @db.Uuid
  // Core fields
  iocType          IocType      @map("ioc_type")
  value            String       @db.Text
  normalizedValue  String       @map("normalized_value") @db.Text
  dedupeHash       String       @unique @map("dedupe_hash") @db.VarChar(64)
  // Classification
  severity         Severity     @default(medium)
  tlp              TLP          @default(amber)
  confidence       Int          @default(50)   // 0-100
  lifecycle        IocLifecycle @default(new)
  // Intel metadata
  tags             String[]     @default([])
  mitreAttack      String[]     @default([]) @map("mitre_attack")
  malwareFamilies  String[]     @default([]) @map("malware_families")
  threatActors     String[]     @default([]) @map("threat_actors")
  // Enrichment
  enrichmentData   Json?        @map("enrichment_data")   // EnrichmentOutput JSON
  enrichedAt       DateTime?    @map("enriched_at")
  // Timestamps
  firstSeen        DateTime     @default(now()) @map("first_seen")
  lastSeen         DateTime     @default(now()) @map("last_seen")
  expiresAt        DateTime?    @map("expires_at")
  // Retention (I-20)
  archivedAt       DateTime?    @map("archived_at")
  archiveReason    String?      @map("archive_reason") @db.VarChar(50)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feedSource FeedSource? @relation(fields: [feedSourceId], references: [id], onDelete: SetNull)
  @@index([tenantId])
  @@index([tenantId, iocType])
  @@index([tenantId, severity])
  @@index([tenantId, lifecycle])
  @@index([normalizedValue])
  @@index([firstSeen])
  @@index([lastSeen])
  @@map("iocs")
}

// ─── Threat Actor Profiles (Module 08 — threat-actor-intel) ───────────
enum ActorType {
  nation_state
  criminal
  hacktivist
  insider
  competitor
  unknown
  @@map("actor_type_enum")
}

enum ActorMotivation {
  financial
  espionage
  hacktivism
  sabotage
  ideology
  unknown
  @@map("actor_motivation_enum")
}

enum ActorSophistication {
  none
  minimal
  intermediate
  advanced
  expert
  strategic
  @@map("actor_sophistication_enum")
}

model ThreatActorProfile {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String              @map("tenant_id") @db.Uuid
  name              String              @db.VarChar(255)
  aliases           String[]            @default([])
  description       String              @default("") @db.Text
  actorType         ActorType           @default(unknown) @map("actor_type")
  motivation        ActorMotivation     @default(unknown)
  sophistication    ActorSophistication @default(none)
  country           String?             @db.VarChar(100)
  targetSectors     String[]            @default([]) @map("target_sectors")
  targetRegions     String[]            @default([]) @map("target_regions")
  ttps              String[]            @default([])
  associatedMalware String[]            @default([]) @map("associated_malware")
  tlp               TLP                 @default(amber)
  confidence        Int                 @default(50)
  tags              String[]            @default([])
  firstSeen         DateTime?           @map("first_seen")
  lastSeen          DateTime?           @map("last_seen")
  active            Boolean             @default(true)
  // Retention (I-20)
  archivedAt        DateTime?           @map("archived_at")
  archiveReason     String?             @map("archive_reason") @db.VarChar(50)
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, active])
  @@index([tenantId, actorType])
  @@index([tenantId, motivation])
  @@index([tenantId, country])
  @@map("threat_actor_profiles")
}

// ─── Malware Profiles (Module 09 — malware-intel) ──────────────────────
enum MalwareType {
  ransomware
  rat
  wiper
  backdoor
  infostealer
  botnet
  rootkit
  trojan
  loader
  worm
  dropper
  keylogger
  adware
  spyware
  unknown
  @@map("malware_type_enum")
}

model MalwareProfile {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String       @map("tenant_id") @db.Uuid
  name              String       @db.VarChar(255)
  aliases           String[]     @default([])
  description       String       @default("") @db.Text
  malwareType       MalwareType  @default(unknown) @map("malware_type")
  platforms         String[]     @default([])
  capabilities      String[]     @default([])
  killChainPhases   String[]     @default([]) @map("kill_chain_phases")
  associatedActors  String[]     @default([]) @map("associated_actors")
  tlp               TLP          @default(amber)
  confidence        Int          @default(50)
  tags              String[]     @default([])
  firstSeen         DateTime?    @map("first_seen")
  lastSeen          DateTime?    @map("last_seen")
  active            Boolean      @default(true)
  // Retention (I-20)
  archivedAt        DateTime?    @map("archived_at")
  archiveReason     String?      @map("archive_reason") @db.VarChar(50)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  tenant            Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, active])
  @@index([tenantId, malwareType])
  @@map("malware_profiles")
}

// ─── Vulnerability Profiles (Module 10 — vulnerability-intel) ───────────

model VulnerabilityProfile {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  cveId             String    @map("cve_id") @db.VarChar(20)
  description       String    @default("") @db.Text
  publishedDate     DateTime? @map("published_date")
  modifiedDate      DateTime? @map("modified_date")
  // CVSS v3
  cvssV3Score       Float     @default(0) @map("cvss_v3_score")
  cvssV3Vector      String?   @map("cvss_v3_vector") @db.VarChar(255)
  cvssV3Severity    String    @default("none") @map("cvss_v3_severity") @db.VarChar(20)
  // EPSS
  epssScore         Float     @default(0) @map("epss_score")
  epssPercentile    Float     @default(0) @map("epss_percentile")
  // Exploit status
  cisaKev           Boolean   @default(false) @map("cisa_kev")
  exploitedInWild   Boolean   @default(false) @map("exploited_in_wild")
  exploitAvailable  Boolean   @default(false) @map("exploit_available")
  // Context
  affectedProducts  String[]  @default([]) @map("affected_products")
  affectedVendors   String[]  @default([]) @map("affected_vendors")
  weaknessType      String?   @map("weakness_type") @db.VarChar(20)
  references        String[]  @default([])
  associatedMalware String[]  @default([]) @map("associated_malware")
  associatedActors  String[]  @default([]) @map("associated_actors")
  // Computed scoring
  priorityScore     Float     @default(0) @map("priority_score")
  // Standard fields
  tlp               TLP       @default(amber)
  confidence        Int       @default(50)
  tags              String[]  @default([])
  active            Boolean   @default(true)
  firstSeen         DateTime? @map("first_seen")
  lastSeen          DateTime? @map("last_seen")
  // Retention (I-20)
  archivedAt        DateTime? @map("archived_at")
  archiveReason     String?   @map("archive_reason") @db.VarChar(50)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@unique([tenantId, cveId])
  @@index([tenantId])
  @@index([tenantId, active])
  @@index([tenantId, cvssV3Severity])
  @@index([tenantId, cisaKev])
  @@index([tenantId, priorityScore])
  @@map("vulnerability_profiles")
}

// ─── Billing (Module 19 — billing-service persistence) ───────────────────

model TenantSubscription {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  plan               Plan      @default(free)
  status             String    @default("active") @db.VarChar(20)  // active, trialing, past_due, cancelled
  previousPlan       Plan?     @map("previous_plan")
  scheduledPlan      Plan?     @map("scheduled_plan")
  scheduledPlanAt    DateTime? @map("scheduled_plan_at")
  razorpayCustomerId String?   @map("razorpay_customer_id") @db.VarChar(255)
  razorpaySubId      String?   @map("razorpay_sub_id") @db.VarChar(255)
  trialEndsAt        DateTime? @map("trial_ends_at")
  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
