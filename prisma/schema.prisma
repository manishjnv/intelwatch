// ── Command Center: Global AI Processing Costs ─────────────────────
// Global table (no tenant_id). One row per AI call per item/subtask.
model AiProcessingCost {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId       String   @map("item_id") @db.VarChar(255)
  itemType     String   @map("item_type") @db.VarChar(20)   // 'article' | 'ioc' | 'report'
  subtask      String   @db.VarChar(50)
  provider     String   @db.VarChar(20)                      // 'anthropic' | 'openai' | 'google'
  model        String   @db.VarChar(50)
