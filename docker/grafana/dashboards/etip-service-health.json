{
  "uid": "etip-service-health",
  "title": "ETIP Service Health",
  "description": "Real-time health overview of all 33 ETIP containers. Prometheus self-metrics (up{}) track scrape targets. NOTE: Services do not yet expose /metrics endpoints — add prom-client + fastify-metrics to each service and uncomment scrape jobs in docker/prometheus/prometheus.yml to populate per-service panels.",
  "tags": ["etip", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "etip-prometheus" },
        "query": "label_values(up, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Targets UP",
      "description": "Total Prometheus scrape targets currently reachable. Add prom-client to ETIP services and configure scrape jobs to see all 33 containers here.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "etip-prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#ef4444", "value": null },
              { "color": "#f59e0b", "value": 1 },
              { "color": "#22c55e", "value": 2 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(up == 1)",
          "legendFormat": "UP",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Targets DOWN",
      "description": "Prometheus scrape targets that are unreachable or returning errors.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "etip-prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#22c55e", "value": null },
              { "color": "#f59e0b", "value": 1 },
              { "color": "#ef4444", "value": 3 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(up == 0)",
          "legendFormat": "DOWN",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Overall Health %",
      "description": "Percentage of all scrape targets that are UP. 100% = all targets reachable.",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "etip-prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#ef4444", "value": null },
              { "color": "#f59e0b", "value": 70 },
              { "color": "#22c55e", "value": 90 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(count(up == 1) / count(up)) * 100",
          "legendFormat": "Health",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Prometheus Uptime",
      "description": "How long the Prometheus server has been running.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "etip-prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#22c55e", "value": null }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - process_start_time_seconds{job=\"prometheus\"}",
          "legendFormat": "Uptime",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Per-Service Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Scrape Target Status",
      "description": "Table showing each Prometheus scrape target with its current status. To see all 33 ETIP containers here, add prom-client to each service and configure scrape_configs in docker/prometheus/prometheus.yml.",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "etip-prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false, "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "DOWN", "color": "#ef4444" }, "1": { "text": "UP", "color": "#22c55e" } } }
                ]
              },
              { "id": "displayName", "value": "Status" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "job" },
            "properties": [
              { "id": "displayName", "value": "Service" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "instance" },
            "properties": [
              { "id": "displayName", "value": "Instance" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "displayName", "value": "Last Scrape" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Status", "desc": false }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=~\"$job\"}",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true },
            "renameByName": {}
          }
        }
      ]
    },
    {
      "id": 8,
      "title": "Response Times",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "HTTP Request Duration — p50 / p95 / p99",
      "description": "Metric not yet exported. Add prom-client with fastify-metrics plugin to each service to expose http_request_duration_seconds histogram. Then uncomment scrape jobs in docker/prometheus/prometheus.yml. Expected metric: http_request_duration_seconds_bucket{service=~\"etip_.*\"}",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "etip-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "pointSize": 5,
            "showPoints": "auto",
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#22c55e", "value": null },
              { "color": "#f59e0b", "value": 0.5 },
              { "color": "#ef4444", "value": 1 }
            ]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\"}[5m])) by (le, job))",
          "legendFormat": "{{ job }} p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\"}[5m])) by (le, job))",
          "legendFormat": "{{ job }} p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\"}[5m])) by (le, job))",
          "legendFormat": "{{ job }} p99"
        }
      ]
    },
    {
      "id": 10,
      "title": "Scrape Duration per Target",
      "description": "How long Prometheus takes to scrape each target. High values may indicate overloaded services.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "etip-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 27 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "scrape_duration_seconds{job=~\"$job\"}",
          "legendFormat": "{{ job }}"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": [
    {
      "title": "Pipeline Overview",
      "url": "/d/etip-pipeline-overview/etip-pipeline-overview",
      "type": "link",
      "icon": "graph-bar"
    },
    {
      "title": "Pipeline & Queues",
      "url": "/d/etip-pipeline-queues/etip-pipeline-queues",
      "type": "link",
      "icon": "bolt"
    },
    {
      "title": "AI Cost Tracking",
      "url": "/d/etip-ai-cost/etip-ai-cost-tracking",
      "type": "link",
      "icon": "dollar-sign"
    },
    {
      "title": "Feed Health",
      "url": "/d/etip-feed-health/etip-feed-health",
      "type": "link",
      "icon": "rss"
    },
    {
      "title": "API Gateway",
      "url": "/d/etip-api-gateway/etip-api-gateway",
      "type": "link",
      "icon": "cloud"
    }
  ]
}
